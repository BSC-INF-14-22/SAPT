# ============================================================
#  SAPPT Backend - Environment Variables
#  HOW TO USE:
#    1. Copy this file: cp .env.example .env
#    2. Fill in YOUR real values below
#    3. NEVER commit the .env file to Git (it's in .gitignore)
# ============================================================

# Port the server will listen on (default: 3000)
PORT=3000

# Firebase Admin SDK credentials
# Get this JSON file from:
#   Firebase Console → Project Settings → Service Accounts
#   → Generate New Private Key → download the .json file
#   → Put it in the backend/ folder and set this path
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Your Firebase Project ID (found in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id
